<b:widget id='Stats1' locked='false' title='Total Pageviews' type='Stats'>
  <b:widget-settings>
    <b:widget-setting name='showGraphicalCounter' data-mor-field='text|Graphical counter|true,false'>false</b:widget-setting>
    <b:widget-setting name='showAnimatedCounter' data-mor-field='text|Animated counter|true,false'>false</b:widget-setting>
    <b:widget-setting name='showSparkline' data-mor-field='text|Show sparkline|true,false'>true</b:widget-setting>
    <b:widget-setting name='sparklineStyle' data-mor-field='text|Sparkline style'>BLACK_TRANSPARENT</b:widget-setting>
    <b:widget-setting name='timeRange' data-mor-field='text|Time range'>ALL_TIME</b:widget-setting>
  </b:widget-settings>
  <b:includable id='main'>
  <b:if cond='data:title != &quot;&quot;'><h2 class='title'><span data-field-path='widget.Stats1.title'><data:title/></span></h2></b:if>
  <div class='widget-content'>
    <div expr:id='data:widget.instanceId + &quot;_content&quot;' style='display: none;'>
      <b:if cond='data:showSparkline'>
        <script src='https://www.gstatic.com/charts/loader.js' type='text/javascript'/>
        <span expr:id='data:widget.instanceId + &quot;_sparklinespan&quot;' style='display:inline-block; width:75px; height:30px'/>
      </b:if>
      <span expr:class='&quot;counter-wrapper &quot; + (data:showGraphicalCounter ? &quot;graph-counter-wrapper&quot; : &quot;text-counter-wrapper&quot;)' expr:id='data:widget.instanceId + &quot;_totalCount&quot;'>
      </span>
      <b:include name='quickedit'/>
    </div>
  </div>
</b:includable>
</b:widget>
